# Backend secrets — copy to .env and fill in. NEVER commit .env.
# All third-party keys are backend-only and never shipped to the client.
TMDB_API_KEY=
ANTHROPIC_API_KEY=
RAPIDAPI_KEY=

# CORS: the frontend origin allowed to call this API.
ALLOWED_ORIGIN=http://localhost:5173

# Cache
CACHE_TTL_SECONDS=86400

# Anthropic model
ANTHROPIC_MODEL=claude-opus-4-8
